{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/session-hook.py\" start",
            "statusMessage": "Loading Thoth runtime context"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/session-hook.py\" end",
            "statusMessage": "Recording Thoth session summary"
          }
        ]
      }
    ]
  }
}
