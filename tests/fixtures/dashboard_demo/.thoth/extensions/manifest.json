{
  "schema_version": 1,
  "plugins": [
    {
      "id": "demo-llm-metrics",
      "title": "Demo LLM Metrics",
      "version": "0.3.0",
      "enabled": true,
      "surfaces": ["dashboard", "tui"],
      "capabilities": ["metrics_provider", "loss_provider"],
      "source": ".thoth/extensions/plugins/demo-llm-metrics",
      "config": {
        "run_name": "demo-llm-pretrain-7b",
        "metrics_files": [
          ".thoth/extensions/plugins/demo-llm-metrics/metrics.jsonl"
        ]
      }
    },
    {
      "id": "demo-readonly-eval",
      "title": "Demo Eval Summary",
      "version": "0.3.0",
      "enabled": true,
      "surfaces": ["dashboard", "tui"],
      "capabilities": ["readonly_provider"],
      "source": ".thoth/extensions/plugins/demo-readonly-eval",
      "config": {
        "panel": "eval-summary"
      }
    },
    {
      "id": "demo-system",
      "title": "Demo System Snapshot",
      "version": "0.3.0",
      "enabled": true,
      "surfaces": ["dashboard", "tui"],
      "capabilities": ["system_provider", "gpu_provider"],
      "source": ".thoth/extensions/plugins/demo-system",
      "config": {
        "system_file": ".thoth/extensions/plugins/demo-system/system.json"
      }
    }
  ],
  "builtin_tools": [
    {
      "id": "todo",
      "title": "Local Todo",
      "kind": "tool",
      "capabilities": ["local_db_write"],
      "enabled": true,
      "description": "Project-local todo database tools isolated from authority."
    },
    {
      "id": "thoth-triggers",
      "title": "Thoth Triggers",
      "kind": "tool",
      "capabilities": ["command_trigger"],
      "enabled": true,
      "description": "Explicit dashboard actions for validate, sync, and health-check commands."
    }
  ]
}
