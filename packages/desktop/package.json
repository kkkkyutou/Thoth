{
  "name": "@thoth/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Thoth desktop app (Electron wrapper)",
  "homepage": "https://thoth.sh",
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "Mohamed Boudra",
    "email": "hello@moboudra.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thoth/thoth.git"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm --prefix ../.. run build:web && npm --prefix ../.. run build:daemon && npm --prefix ../.. run build:cli && npm run build:main && electron-builder --config electron-builder.yml",
    "build:linux-appimage": "npm --prefix ../.. run build:web && npm --prefix ../.. run build:daemon && npm --prefix ../.. run build:cli && npm run build:main && electron-builder --config electron-builder.yml --linux AppImage",
    "build:main": "tsc -p tsconfig.json",
    "dev": "./scripts/dev.sh",
    "dev:win": "powershell ./scripts/dev.ps1",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@thoth/cli": "file:../cli",
    "@thoth/daemon": "file:../daemon",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "ws": "^8.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/ws": "^8.5.14",
    "electron": "41.2.0",
    "electron-builder": "26.8.1",
    "typescript": "5.9.3",
    "unzip-crx-3": "^0.2.0",
    "vitest": "^4.1.6",
    "wait-on": "8.0.5"
  }
}
